# Robinhood Chain testnet configuration
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
DEPLOYER_PRIVATE_KEY=

# Operational roles. Defaults to the deployer if omitted by the deployment script.
ADMIN_ADDRESS=
TREASURY_ADDRESS=
ORACLE_ADDRESS=

# Testnet-only operational constraints.
BASE_SET_MAX_CONTRIBUTION_ETH=0.05
BASE_SET_EXPECTED_COMPONENTS=16

# Optional metadata digests. Use 0x-prefixed 32-byte hex values for reproducible deployment manifests.
BASE_SET_METHODOLOGY_DIGEST=
BASE_SET_DOCUMENTATION_DIGEST=
